# ===== El Pajaro — variables de entorno =====
# Copia este archivo como .env y llenalo. .env esta en .gitignore.

# Puerto del server. Render lo inyecta automaticamente — en local usa 3000.
PORT=3000

# ===== Twitch =====
# Crear la app en https://dev.twitch.tv/console/apps
# Redirect URLs a registrar (las dos):
#   http://localhost:3000/api/twitch/callback
#   https://elpajaro.stream/api/twitch/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Nombre publico del bot que aparece al leer chat (cualquier string).
# El JOIN al canal usa el broadcaster_login del OAuth, no este nombre.
TWITCH_BOT_NICK=elpajaro_bot

# ===== PINs por pais (panel del show) =====
# Dos PINs separados, uno por streamer. /panel/cuba pide PIN_CUBA,
# /panel/pr pide PIN_PR. /panel/master entra con cualquiera de los dos.
# Cambialos a valores largos y unicos antes de desplegar.
PIN_CUBA=cuba1234
PIN_PR=pr1234

# Opcional: PIN dedicado del master. Si no se setea, master usa CUALQUIERA
# de PIN_CUBA o PIN_PR (es la pantalla compartida que ven ambos streamers).
# PIN_MASTER=

# Compatibilidad hacia atras: si solo seteas HOST_PIN, los 3 roles lo aceptan.
# HOST_PIN=

# ===== Tiempos por defecto =====
# Duracion de la votacion en milisegundos (override-able desde el panel).
DEFAULT_VOTE_DURATION_MS=60000

# ===== Firebase (opcional — sin esto persiste a disco local en data/) =====
# Si querés persistencia cross-restart usá Firebase. El service-account JSON
# se pega como string completo en una sola linea, escapando los \n a \\n.
# Si no esta seteado, el server cae a persistir en data/state.json.
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_PROJECT_ID=
